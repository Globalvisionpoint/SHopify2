<section class="collection-page section-space search-page">
  <div class="page-width page-backdrop">
    <div class="collection-page__toolbar">
      <div>
        <p class="collection-page__crumbs">
          <a href="{{ routes.root_url }}">Prima pagina</a>
          <span>/</span>
          <span>Rezultate de cautare pentru "{{ search.terms }}"</span>
        </p>
        <h1 class="collection-page__title">Rezultatele cautarii pentru: "{{ search.terms }}"</h1>
      </div>

      {% if search.results_count > 0 %}
        <form class="collection-page__sort" method="get">
          <label for="SortBy">Sorteaza...</label>
          <select name="sort_by" id="SortBy" onchange="this.form.submit()">
            <option value="relevance">Relevanta</option>
            <option value="title-ascending">Titlu (A-Z)</option>
            <option value="title-descending">Titlu (Z-A)</option>
            <option value="price-ascending">Pret (Ascending)</option>
            <option value="price-descending">Pret (Descending)</option>
          </select>
        </form>
      {% endif %}
    </div>

    <div class="collection-page__layout">
      <aside class="collection-sidebar">
        {% if search.filters.size > 0 %}
          {% for filter in search.filters %}
            <details class="collection-sidebar__group" open>
              <summary>{{ filter.label }}</summary>
              <div class="collection-sidebar__content">
                {% case filter.type %}
                  {% when 'list' %}
                    {% for value in filter.values %}
                      <a href="{% if value.active %}{{ value.url_to_remove }}{% else %}{{ value.url_to_add }}{% endif %}" class="facet-link {% if value.active %}is-active{% endif %}">
                        {{ value.label }}
                        <span>{{ value.count }}</span>
                      </a>
                    {% endfor %}
                  {% when 'price_range' %}
                    <div class="facet-price">
                      <span>{{ filter.min_value.value | default: 0 | money_without_trailing_zeros }}</span>
                      <span>-</span>
                      <span>{{ filter.max_value.value | default: filter.range_max | money_without_trailing_zeros }}</span>
                    </div>
                {% endcase %}
              </div>
            </details>
          {% endfor %}
        {% else %}
          <details class="collection-sidebar__group" open>
            <summary>Categorii</summary>
            <div class="collection-sidebar__content">
              <p class="collection-sidebar__hint">Configureaza filtrele din Shopify Search & Discovery.</p>
            </div>
          </details>

          <details class="collection-sidebar__group" open>
            <summary>Pret</summary>
            <div class="collection-sidebar__content">
              <p class="collection-sidebar__hint">Configureaza filtrele din Shopify Search & Discovery.</p>
            </div>
          </details>
        {% endif %}
      </aside>

      <div>
        {% if search.performed %}
          {% if search.results_count == 0 %}
            <div class="search-no-results">
              <p>Nu am gasit produse pentru "{{ search.terms }}"</p>
              <p>Incearca cu alti termeni de cautare.</p>
            </div>
          {% else %}
            {% paginate search.results by 12 %}
              <div class="collection-grid">
                {% for item in search.results %}
                  {% if item.object_type == 'product' %}
                    {% render 'product-card', product: item %}
                  {% endif %}
                {% endfor %}
              </div>

              {% if paginate.pages > 1 %}
                <nav class="pagination" aria-label="Paginare cautare">
                  {% if paginate.previous %}
                    <a href="{{ paginate.previous.url }}" class="pagination__item">Anterior</a>
                  {% endif %}
                  <span class="pagination__item pagination__item--current">{{ paginate.current_page }} / {{ paginate.pages }}</span>
                  {% if paginate.next %}
                    <a href="{{ paginate.next.url }}" class="pagination__item">Urmator</a>
                  {% endif %}
                </nav>
              {% endif %}
            {% endpaginate %}
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .search-page {
    margin-top: 3cm;
  }

  .search-no-results {
    text-align: center;
    padding: 60px 20px;
  }

  .search-no-results p {
    font-size: 1.1rem;
    color: #666;
    margin: 10px 0;
  }

  .facet-link {
    display: block;
    padding: 8px 0;
    color: #1f1f25;
    text-decoration: none;
    border-bottom: 1px solid #e5e5e5;
  }

  .facet-link:hover {
    text-decoration: underline;
  }

  .facet-link.is-active {
    color: var(--color-primary);
    font-weight: 600;
  }

  .facet-link span {
    float: right;
    color: #999;
  }

  .facet-price {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 12px;
  }
</style>


