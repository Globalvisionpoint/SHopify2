<header
  class="header header--sticky-fixed"
  data-header
  style="
    --header-glass-opacity: {{ section.settings.header_glass_opacity | divided_by: 100.0 }};
    --header-grad-start: {{ section.settings.header_grad_start | color_modify: 'alpha', section.settings.header_grad_start_alpha | divided_by: 100.0 }};
    --header-grad-end: {{ section.settings.header_grad_end | color_modify: 'alpha', section.settings.header_grad_end_alpha | divided_by: 100.0 }};
    --header-grad-angle: {{ section.settings.header_grad_angle }}deg;
    --header-blur: {{ section.settings.header_blur }}px;
  "
>
  <div class="page-width header__inner">
    <a class="header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 220 | image_tag: class: 'header__logo-image', alt: shop.name, widths: '110, 160, 220' }}
      {% else %}
        <span class="header__logo-mark">CD</span>
        <span class="header__logo-text">{{ shop.name }}</span>
      {% endif %}
    </a>

    <button class="header__catalog-toggle" type="button" data-catalog-toggle aria-expanded="false" aria-controls="catalog-menu">
      {% render 'icon', name: 'menu' %}
      <span>{{ section.settings.catalog_label }}</span>
      {% render 'icon', name: 'chevron-down' %}
    </button>

    <a href="{% if section.settings.deals_collection %}{{ section.settings.deals_collection.url }}{% else %}{{ routes.all_products_collection_url }}{% endif %}" class="header__deals" aria-label="Reduceri">
      <span class="header__deals-icon" aria-hidden="true"></span>
      <span>Reduceri</span>
    </a>

    <form action="{{ routes.search_url }}" method="get" role="search" class="header__search">
      <input type="hidden" name="type" value="product">
      <label class="visually-hidden" for="Search-In-Modal">Cauta produse</label>
      <input
        id="Search-In-Modal"
        class="header__search-input"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ section.settings.search_placeholder }}"
      >
      <button class="header__search-button" type="submit" aria-label="Cauta">
        {% render 'icon', name: 'search' %}
      </button>
    </form>

    <div class="header__actions">
      <a class="header__action" href="{{ routes.account_url }}" aria-label="Cont">
        {% render 'icon', name: 'account' %}
      </a>
      <a class="header__action header__action--wishlist" href="/pages/wishlist" aria-label="Favorite">
        {% render 'icon', name: 'heart' %}
      </a>
      <a class="header__action" href="{{ routes.cart_url }}" aria-label="Cos">
        {% render 'icon', name: 'cart' %}
        <span class="header__cart-count" data-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>

  {%- comment -%} ===== DESKTOP MEGA MENU ===== {%- endcomment -%}
  <div id="catalog-menu" class="mega-menu" data-mega-menu hidden>
    <div class="mega-menu__shell">

      {%- comment -%} --- LEFT SIDEBAR: categorii principale --- {%- endcomment -%}
      <aside class="mega-menu__sidebar">

