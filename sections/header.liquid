<header class="header" data-header>
  <div class="page-width header__inner">
    <a class="header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 220 | image_tag: class: 'header__logo-image', alt: shop.name, widths: '110, 160, 220' }}
      {% else %}
        <span class="header__logo-mark">CD</span>
        <span class="header__logo-text">{{ shop.name }}</span>
      {% endif %}
    </a>

    <button class="header__catalog-toggle" type="button" data-catalog-toggle aria-expanded="false" aria-controls="catalog-menu">
      {% render 'icon', name: 'menu' %}
      <span>{{ section.settings.catalog_label }}</span>
      {% render 'icon', name: 'chevron-down' %}
    </button>

    <nav class="header__links" aria-label="Navigatie principala">
      {% if section.settings.menu != blank %}
        {% for link in section.settings.menu.links limit: 6 %}
          <a href="{{ link.url }}" class="header__link">{{ link.title }}</a>
        {% endfor %}
      {% endif %}
      {% if section.settings.sale_link_label != blank and section.settings.sale_link != blank %}
        <a href="{{ section.settings.sale_link }}" class="header__link header__link--accent">{{ section.settings.sale_link_label }}</a>
      {% endif %}
    </nav>

    <form action="{{ routes.search_url }}" method="get" role="search" class="header__search">
      <input type="hidden" name="type" value="product">
      <label class="visually-hidden" for="Search-In-Modal">Cauta produse</label>
      <input
        id="Search-In-Modal"
        class="header__search-input"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ section.settings.search_placeholder }}"
      >
      <button class="header__search-button" type="submit" aria-label="Cauta">
        {% render 'icon', name: 'search' %}
      </button>
    </form>

    <div class="header__actions">
      <a class="header__action" href="{{ routes.account_url }}" aria-label="Cont">
        {% render 'icon', name: 'account' %}
      </a>
      <a class="header__action" href="{{ routes.cart_url }}" aria-label="Cos">
        {% render 'icon', name: 'cart' %}
        <span class="header__cart-count" data-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>

  {% if section.settings.menu != blank and section.settings.menu.links.size > 0 %}
    <div id="catalog-menu" class="mega-menu" data-mega-menu hidden>
      <div class="page-width mega-menu__shell">
        <aside class="mega-menu__sidebar" aria-label="Categorii meniu">
          {% for link in section.settings.menu.links %}
            <button
              type="button"
              class="mega-menu__category {% if forloop.first %}is-active{% endif %}"
              data-mega-trigger="{{ forloop.index0 }}"
              aria-controls="mega-panel-{{ forloop.index0 }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              <span>{{ link.title }}</span>
              <span class="mega-menu__category-arrow" aria-hidden="true">></span>
            </button>
          {% endfor %}
        </aside>

        <div class="mega-menu__content">
          {% for link in section.settings.menu.links %}
            <div id="mega-panel-{{ forloop.index0 }}" class="mega-menu__panel {% if forloop.first %}is-active{% endif %}" data-mega-panel="{{ forloop.index0 }}">
              {% if link.links.size > 0 %}
                <div class="mega-menu__columns">
                  {% for child in link.links limit: 5 %}
                    <section class="mega-menu__column">
                      <a class="mega-menu__column-title" href="{{ child.url }}">{{ child.title }}</a>

                      {% if child.links.size > 0 %}
                        <ul class="mega-menu__list" role="list">
                          {% for grandchild in child.links limit: 8 %}
                            <li>
                              <a href="{{ grandchild.url }}" class="mega-menu__item-link">{{ grandchild.title }}</a>
                            </li>
                          {% endfor %}
                        </ul>
                      {% else %}
                        <ul class="mega-menu__list" role="list">
                          <li>
                            <a href="{{ child.url }}" class="mega-menu__item-link">Vezi produsele</a>
                          </li>
                        </ul>
                      {% endif %}

                      <a class="mega-menu__all-link" href="{{ child.url }}">Vezi tot</a>
                    </section>
                  {% endfor %}
                </div>
              {% else %}
                <div class="mega-menu__empty">
                  <h3>{{ link.title }}</h3>
                  <p>Configureaza submeniuri in navigatia Shopify pentru a afisa coloane ca in exemplu.</p>
                  <a href="{{ link.url }}" class="button button--primary">Vezi categoria</a>
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <button class="mega-menu-backdrop" data-mega-backdrop hidden aria-label="Inchide meniul"></button>
  {% endif %}

  <div id="mobile-menu" class="mobile-menu" data-mobile-menu hidden>
    <div class="mobile-menu__panel">
      <div class="mobile-menu__top">
        <span class="mobile-menu__title">Meniu</span>
        <button type="button" class="mobile-menu__close" data-mobile-menu-close aria-label="Inchide meniul">
          {% render 'icon', name: 'close' %}
        </button>
      </div>

      {% if section.settings.menu != blank %}
        <nav class="mobile-menu__nav" aria-label="Navigatie mobila">
          {% for link in section.settings.menu.links %}
            <a href="{{ link.url }}" class="mobile-menu__link">{{ link.title }}</a>
          {% endfor %}
        </nav>
      {% endif %}

      {% if section.settings.sale_link_label != blank and section.settings.sale_link != blank %}
        <a href="{{ section.settings.sale_link }}" class="mobile-menu__sale">{{ section.settings.sale_link_label }}</a>
      {% endif %}
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Meniu principal"
    },
    {
      "type": "text",
      "id": "catalog_label",
      "label": "Text buton catalog",
      "default": "Magazin"
    },
    {
      "type": "text",
      "id": "sale_link_label",
      "label": "Text link promotii",
      "default": "Reduceri"
    },
    {
      "type": "url",
      "id": "sale_link",
      "label": "Link promotii"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Placeholder cautare",
      "default": "Incepe o cautare..."
    }
  ]
}
{% endschema %}