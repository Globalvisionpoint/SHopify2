<section class="category-grid section-space">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <div class="section-heading section-heading--center">
        <span class="section-heading__pill">{{ section.settings.heading }}</span>
      </div>
    {% endif %}

    <div class="category-grid__items">
      {% for block in section.blocks %}
        {% assign selected_collection = block.settings.collection %}
        {% assign card_link = block.settings.link %}
        {% if selected_collection != blank %}
          {% assign card_link = selected_collection.url %}
        {% endif %}

        {% assign card_title = block.settings.title %}
        {% if card_title == blank and selected_collection != blank %}
          {% assign card_title = selected_collection.title %}
        {% endif %}

        <a href="{{ card_link | default: routes.all_products_collection_url }}" class="category-card" {{ block.shopify_attributes }}>
          <div class="category-card__media">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 480 | image_tag: class: 'category-card__image', alt: card_title, widths: '160, 240, 320, 480' }}
            {% elsif selected_collection != blank and selected_collection.featured_image != blank %}
              {{ selected_collection.featured_image | image_url: width: 480 | image_tag: class: 'category-card__image', alt: card_title, widths: '160, 240, 320, 480' }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'category-card__image category-card__image--placeholder' }}
            {% endif %}
          </div>
          <span class="category-card__title">{{ card_title | default: 'Categorie' }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titlu sectiune",
      "default": "Categorii"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categorie",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Colectie Shopify"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagine (optional, suprascrie imaginea colectiei)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titlu (optional, suprascrie titlul colectiei)",
          "default": ""
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link manual (optional, folosit doar daca nu alegi colectie)"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Category grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Produse iHunt" } },
        { "type": "category", "settings": { "title": "Electrocasnice" } },
        { "type": "category", "settings": { "title": "Decoratiuni" } },
        { "type": "category", "settings": { "title": "Bucatarie" } },
        { "type": "category", "settings": { "title": "Auto-Moto" } },
        { "type": "category", "settings": { "title": "Animale" } },
        { "type": "category", "settings": { "title": "Jucarii" } }
      ]
    }
  ]
}
{% endschema %}